{
  "name": "duffy-ai",
  "version": "0.0.1",
  "private": true,
  "description": "Duffy — autonomous Instagram content agent on Mastra, talking to brands via WhatsApp through Kapso.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "reset-brand": "tsx src/scripts/resetBrand.ts",
    "deploy": "railway up"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "@hono/node-server": "^2.0.0",
    "@mastra/core": "^1.28.0",
    "@mastra/memory": "^1.17.1",
    "@mastra/pg": "^1.9.2",
    "ai": "^6.0.168",
    "apify-client": "^2.23.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "pg-boss": "^12.17.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
