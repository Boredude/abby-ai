# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
PUBLIC_BASE_URL=https://your-public-url.example

# --- Database (Neon Postgres) ---
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# --- Kapso (WhatsApp) ---
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=
KAPSO_BUSINESS_ACCOUNT_ID=
KAPSO_WEBHOOK_SECRET=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1
# ChatGPT Images 2 — confirm exact slug at runtime; default to gpt-image-2
OPENAI_IMAGE_MODEL=gpt-image-2

# --- Anthropic (Duffy orchestrator + OnboardingAgent) ---
ANTHROPIC_API_KEY=
# Mastra model-gateway strings; override to swap models without code changes.
DUFFY_ORCHESTRATOR_MODEL=anthropic/claude-haiku-4-5
ONBOARDING_AGENT_MODEL=anthropic/claude-sonnet-4-5

# --- Google Gemini (used by the creative pipeline defaults) ---
# Required when any CREATIVE_*_MODEL below uses a `google/...` slug.
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Creative pipeline (per-role model slugs) ---
# Each specialist sub-agent in the creative brain uses its own model so we
# can trade cost vs. quality per task. Override any of these to swap.
CREATIVE_DIRECTOR_MODEL=openai/gpt-4o
CREATIVE_IDEATOR_MODEL=google/gemini-3-pro-preview
CREATIVE_COPYWRITER_MODEL=anthropic/claude-sonnet-4-6
CREATIVE_HASHTAG_MODEL=google/gemini-3-pro-preview
CREATIVE_STYLIST_MODEL=openai/gpt-4o
# Image rendering uses OPENAI_IMAGE_MODEL.
# classifyEditIntent reuses CREATIVE_DIRECTOR_MODEL.
# Future reel/video rendering: CREATIVE_VIDEO_MODEL.

# --- Apify (Instagram scraper) ---
APIFY_TOKEN=

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=duffy-media
R2_PUBLIC_BASE_URL=https://media.example.com
